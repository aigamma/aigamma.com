# Supabase project URL (e.g. https://xxxxx.supabase.co) — Project Settings → API → Project URL.
SUPABASE_URL=

# Supabase anon public key — used by data.mjs for SELECT reads through RLS. Project Settings → API → anon public.
SUPABASE_KEY=

# Supabase service role key — bypasses RLS, required by ingest-background.mjs for INSERT writes. Project Settings → API → service_role. Treat as a secret.
SUPABASE_SERVICE_KEY=

# Massive Options API key — used by ingest-background.mjs to fetch the SPX options chain. Get from https://massive.io account settings.
MASSIVE_API_KEY=

# Shared secret between ingest.mjs (cron wrapper) and ingest-background.mjs (worker) — authenticates the internal HTTP dispatch. Generate any random string and set the same value on both functions.
INGEST_SECRET=

# Optional override for the background function URL used by ingest.mjs. Defaults to ${URL}/.netlify/functions/ingest-background. Set only if you need to route to a different host (local dev, branch preview).
INGEST_BACKGROUND_URL=

# Auto-set by the Netlify runtime to the deployed site URL (e.g. https://aigamma.com). Do not set manually — listed here for reference because ingest.mjs reads it as the fallback for INGEST_BACKGROUND_URL.
URL=

# Anthropic API key — used by netlify/functions/chat.mjs to proxy streaming responses from Claude Opus 4.7 for the Ask-the-Dashboard chat component. Get from https://console.anthropic.com. Scoped to the aigamma Netlify project only; the about.aigamma.com project has its own copy of this secret.
ANTHROPIC_API_KEY=
